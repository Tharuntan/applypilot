# ===== ApplyPilot environment variables =====
# Copy to .env and adjust. The backend reads these (see backend/src/main/resources/application.yml).

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/applypilot
DB_USERNAME=applypilot
DB_PASSWORD=applypilot

# --- Security ---
# Use a long random string (>= 32 bytes). Generate one with:  openssl rand -base64 48
JWT_SECRET=ZmFrZS1kZXYtc2VjcmV0LWNoYW5nZS1tZS1hcHBseXBpbG90LTIwMjQtc3VwZXItc2VjcmV0LWtleQ==
JWT_EXPIRATION_MS=86400000

# --- CORS (Angular dev server) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- AI provider (OpenAI-compatible). Leave AI_API_KEY blank to use the free fallback analyzer. ---
# RECOMMENDED (free): Groq — get a key at https://console.groq.com/keys
#   AI_API_KEY=gsk_your_groq_key
#   AI_BASE_URL=https://api.groq.com/openai/v1
#   AI_MODEL=llama-3.3-70b-versatile
# OpenAI (paid):
#   AI_BASE_URL=https://api.openai.com/v1   AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_TIMEOUT_SECONDS=60

# --- Email (password reset + verification). If unset, links are LOGGED instead of sent. ---
FRONTEND_URL=http://localhost:4200
MAIL_FROM=no-reply@applypilot.app
# To actually send email, configure SMTP (Spring reads these SPRING_MAIL_* vars):
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your@gmail.com
# SPRING_MAIL_PASSWORD=your_app_password
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# --- Server ---
SERVER_PORT=8080
